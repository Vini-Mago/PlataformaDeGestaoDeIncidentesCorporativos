# PostgreSQL (Docker Compose + connection strings for services)
POSTGRES_USER=pgic
POSTGRES_PASSWORD=pgic
POSTGRES_DB=identity_service
POSTGRES_PORT=5432

# Connection strings (one Postgres, one DB per service: {name}_service, snake_case).
# Use service-specific vars (IDENTITY_DATABASE_URL, REQUEST_DATABASE_URL) for each service.
# DATABASE_URL: generic/fallback DB URL used by tests or scripts that need a single default (e.g. request_service).
DATABASE_URL=postgresql://pgic:pgic@localhost:5432/request_service
IDENTITY_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/identity_service
REQUEST_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/request_service
INCIDENT_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/incident_service
PROBLEM_CHANGE_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/problem_change_service
SLA_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/sla_service
ESCALATION_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/escalation_service
NOTIFICATION_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/notification_service

# Redis
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

# RabbitMQ (Docker Compose)
RABBITMQ_USER=pgic
RABBITMQ_PASSWORD=pgic
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://pgic:pgic@localhost:5672

# Portas dos serviços
IDENTITY_SERVICE_PORT=3001
REQUEST_SERVICE_PORT=3002
INCIDENT_SERVICE_PORT=3004
PROBLEM_CHANGE_SERVICE_PORT=3005
SLA_SERVICE_PORT=3006
ESCALATION_SERVICE_PORT=3007
NOTIFICATION_SERVICE_PORT=3008
API_DOCS_PORT=3003

# Nginx no Docker: porta no host (container escuta 80). Sem Docker use 80 no host.
GATEWAY_PORT=8080

# Identity: auth
JWT_SECRET=change-me-in-production-use-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
BASE_URL=http://localhost:3001
CORS_ORIGIN=

# OAuth (opcional; deixe em branco para desativar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
