INCIDENT_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/incident_service
INCIDENT_SERVICE_PORT=3004
BASE_URL=http://localhost:3004

# Must match identity-service JWT_SECRET (tokens are issued by identity, verified here).
JWT_SECRET=change-me-in-production-use-a-long-random-secret

# Optional. When set: publishes incident events via Outbox relay; consumes user.created for replication.
# Use same value as root RABBITMQ_URL (e.g. amqp://pgic:pgic@localhost:5672).
# RABBITMQ_URL=amqp://pgic:pgic@localhost:5672
# OUTBOX_RELAY_INTERVAL_MS=2000
