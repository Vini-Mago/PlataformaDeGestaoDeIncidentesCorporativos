{
  "name": "identity-service",
  "version": "1.0.0",
  "private": true,
  "main": "dist/index.js",
  "scripts": {
    "build": "prisma generate && tsc",
    "dev": "ts-node-dev --respawn src/index.ts",
    "test": "vitest run",
    "test:integration": "vitest run --config vitest.integration.config.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:migrate:deploy": "node -e \"const path = require('path'); const dotenv = require('dotenv'); const { execSync } = require('child_process'); dotenv.config({ path: path.resolve(process.cwd(), '../../.env') }); process.env.DATABASE_URL = process.env.IDENTITY_DATABASE_URL; execSync('npx tsx ../../scripts/ensure-database.ts', { stdio: 'inherit', env: process.env }); execSync('npx prisma migrate deploy', { stdio: 'inherit', env: process.env });\"",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@asteasolutions/zod-to-openapi": "7.3.4",
    "@pgic/shared": "workspace:*",
    "@prisma/client": "^6.8.2",
    "amqplib": "^0.10.3",
    "argon2": "^0.41.1",
    "awilix": "^13.0.3",
    "cors": "^2.8.6",
    "express": "^4.21.0",
    "express-rate-limit": "^7.4.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pino": "^9.5.0",
    "swagger-ui-express": "^5.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/amqplib": "^0.10.4",
    "@types/cors": "^2.8.19",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/supertest": "^6.0.2",
    "@types/swagger-ui-express": "^4.1.6",
    "dotenv": "^16.4.5",
    "pino-pretty": "^11.3.0",
    "prisma": "^6.8.2",
    "supertest": "^7.0.0",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.0",
    "vitest": "^2.1.0"
  }
}
