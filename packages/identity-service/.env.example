IDENTITY_DATABASE_URL=postgresql://pgic:pgic@localhost:5432/identity_service
REDIS_URL=redis://localhost:6379
RABBITMQ_URL=amqp://pgic:pgic@localhost:5672
IDENTITY_SERVICE_PORT=3001

# Auth (obrigatório em produção)
JWT_SECRET=change-me-in-production-use-a-long-random-secret
JWT_EXPIRES_IN_SECONDS=604800
BASE_URL=http://localhost:3001
# Deixe vazio para usar origem pública dinâmica (frontend/ngrok) via BFF.
OAUTH_REDIRECT_URL=
OAUTH_REDIRECT_PATH=/auth/callback
PUBLIC_ORIGIN_OVERRIDE=
PUBLIC_ALLOWED_HOST_SUFFIXES=ngrok-free.app,ngrok.app,localhost
PASSWORD_AUTH_ENABLED=false

# OAuth (opcional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
